// Hir3d Application Database Schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/app-client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL_APP")
}

//-----------------------------------------------------------------------------
// Candidate Related Models
//-----------------------------------------------------------------------------

model Candidate {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Basic Info (may be anonymized or partially filled initially)
  firstName   String?
  lastName    String?
  email       String?  @unique // Unique if you want to prevent duplicate candidate entries by email
  phoneNumber String?
  location    String? // Parsed primary location
  websiteUrl  String?
  linkedinUrl String?

  // CV and Extracted Data Storage
  originalCvBlobUri   String? // URI to the original .pdf/.docx in Blob Storage
  extractedTextBlobUri String? // URI to the .txt extracted content in Blob Storage
  cvUploadTimestamp   DateTime?
  cvSource            CvSource @default(UNKNOWN) // e.g., CANDIDATE_UPLOAD, MANUAL_ENTRY, LINKEDIN_SCRAPE

  // AI Processed Data
  aiAnalysisStatus ProcessingStatus @default(PENDING)
  aiLastProcessedAt DateTime?
  aiExtractedSkills Json? // Could be an array of strings or objects: [{ skill: "React", experience: 5, isMustHave: false }]
  aiExtractedExperience Json? // Array of job objects: [{ title: "Dev", company: "Acme", duration: "2 yrs" }]
  aiExtractedEducation Json? // Array of education objects
  aiTags              Json? // General tags/keywords generated by AI (stored as JSON array)
  aiSummary           String? @db.Text // AI-generated summary of the candidate
  overallRankingScore Float?  // A general score if you implement a global ranking

  // Relationships
  jobCandidateMatches JobCandidateMatch[] // How this candidate matches various jobs
  candidateNotes      CandidateNote[]     // Notes added by internal team/recruiters

  // Who owns/manages this candidate if manually added by a specific organization?
  // This helps if you plan multi-tenancy for candidate pools later.
  // For now, assuming a global pool, or a candidate is tied to an org that uploaded them.
  managingOrganizationId String? // References Organization.id from your auth DB

  @@index([aiAnalysisStatus])
  @@index([managingOrganizationId])
}

enum CvSource {
  CANDIDATE_UPLOAD
  MANUAL_ENTRY
  LINKEDIN_SCRAPE
  UNKNOWN
}

enum ProcessingStatus {
  PENDING
  PARSING_CV
  EXTRACTING_TEXT
  ANALYZING_DATA // Generic AI analysis step
  INDEXING
  COMPLETED
  ERROR_PARSING
  ERROR_ANALYSIS
}

model CandidateNote {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  content     String   @db.Text
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  authorId    String // References User.id from your auth DB

  @@index([candidateId])
  @@index([authorId])
}

//-----------------------------------------------------------------------------
// Job Search Related Models
//-----------------------------------------------------------------------------

model JobSearch {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title         String   // AI Generated or User defined
  status        JobSearchStatus @default(DRAFT_CREATED)
  naturalLanguagePrompt String? @db.Text // The initial prompt from the user

  // Foreign keys to your Auth DB. These are CRITICAL.
  // Ensure these IDs match the IDs generated in your Auth DB.
  organizationId String? // The organization (customer) that created this job search - null for personal jobs
  creatorUserId  String // The specific user within that organization who created it

  // Timestamps for lifecycle
  activatedAt DateTime?
  pausedAt    DateTime?
  archivedAt  DateTime?
  lastProcessingStep String? // e.g., "SCANNING_CANDIDATES", "RANKING_MATCHES" from trigger.dev
  processingProgress Json?   // e.g., { current: 100, total: 1000 }

  // Relationships
  criteria          JobSearchCriteria?    // The structured criteria for this job search
  jobCandidateMatches JobCandidateMatch[] // Candidates matched to this job
  savedSearchAlert  SavedSearchAlert?   // If this job search is also a saved alert
  promotedJob       PromotedJob?        // If this job is promoted
  analyticsSnapshots JobAnalyticsSnapshot[] // Analytics data over time

  @@index([organizationId])
  @@index([creatorUserId])
  @@index([status])
}

enum JobSearchStatus {
  DRAFT_CREATED    // Initial state after NL prompt
  PARSING_PROMPT   // AI is working on the NL prompt
  DRAFT_READY      // AI parsed, ready for user review & refine
  PREVIEWING_MATCHES // User is on the live preview step
  ACTIVE           // Actively matching candidates
  PAUSED           // User paused the search
  ARCHIVED         // User archived the search
  ERROR_PARSING_PROMPT
  ERROR_ACTIVATING
}

model JobSearchCriteria {
  id          String   @id @default(cuid())
  jobSearchId String   @unique // One-to-one with JobSearch
  jobSearch   JobSearch @relation(fields: [jobSearchId], references: [id], onDelete: Cascade)
  updatedAt   DateTime @updatedAt

  // Structured criteria (could be a large JSON object)
  // This will hold things like:
  // - skills: [{ name: "React", experienceYears: 3, importance: "MUST_HAVE" }]
  // - locations: ["Berlin", "Remote"]
  // - experienceOverallYears: { min: 5, max: 10 }
  // - salaryRange: { min: 70000, max: 90000, currency: "EUR" }
  // - employmentTypes: ["FULL_TIME"]
  // - educationLevel: "BACHELORS"
  // - keywords: ["agile", "scrum master"]
  // - languageRequirements: [{ language: "German", proficiency: "C1" }]
  criteriaData Json

  // Versioning for criteria changes (optional but very useful)
  version Int @default(1)
}

model JobCandidateMatch {
  id          String   @id @default(cuid())
  jobSearchId String
  jobSearch   JobSearch @relation(fields: [jobSearchId], references: [id], onDelete: Cascade)
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) // When this match was first identified

  matchScore      Float    // Overall score from AI for this specific job
  isShortlisted   Boolean  @default(false)
  shortlistedAt   DateTime?
  isHidden        Boolean  @default(false) // If user hides this candidate for this job
  hiddenAt        DateTime?
  statusForJob    String?  // e.g., "Contacted", "Interview Scheduled", "Rejected by Candidate"
  recruiterNotes  String?  @db.Text // Notes specific to this candidate FOR THIS JOB

  // AI reasoning for the match (optional, could be complex)
  // e.g., { skillMatches: ["React", "Node.js"], experienceAlignment: 0.8 }
  matchDetailsJson Json?

  @@unique([jobSearchId, candidateId]) // A candidate can only be matched once to a specific job search
  @@index([isShortlisted])
  @@index([isHidden])
}

//-----------------------------------------------------------------------------
// User Tooling (My Tools section)
//-----------------------------------------------------------------------------

model SavedSearchAlert {
  id          String   @id @default(cuid())
  jobSearchId String   @unique // A saved search is essentially an active JobSearch used as an alert
  jobSearch   JobSearch @relation(fields: [jobSearchId], references: [id], onDelete: Cascade)

  // Alert specific settings
  alertName         String   // User-defined name for this alert
  alertFrequency    String   @default("IMMEDIATE") // e.g., IMMEDIATE, DAILY, WEEKLY
  lastAlertSentAt   DateTime?
  isNotificationEnabled Boolean @default(true)

  // Foreign keys to Auth DB
  userId          String // The user who saved this search/alert
  organizationId  String // The organization this alert belongs to

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([organizationId])
}

model JobTemplate {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name              String @unique // User-defined name for the template
  description       String? @db.Text
  templateCriteria  Json   // Stores the same structure as JobSearchCriteria.criteriaData

  // Foreign keys to Auth DB
  creatorUserId     String
  organizationId    String

  isPublic          Boolean @default(false) // If you want to allow public/shared templates later

  @@index([organizationId])
  @@index([creatorUserId])
}

//-----------------------------------------------------------------------------
// Future/Gated Features (Placeholders)
//-----------------------------------------------------------------------------

model PromotedJob {
  id             String   @id @default(cuid())
  jobSearchId    String   @unique // The job being promoted
  jobSearch      JobSearch @relation(fields: [jobSearchId], references: [id], onDelete: Cascade)
  promotionStart DateTime
  promotionEnd   DateTime
  budget         Decimal? @db.Decimal(10, 2)
  status         String   // e.g., ACTIVE, EXPIRED, PAUSED
  performanceData Json?    // e.g., { views: 1000, clicks: 50, applicationsFromAd: 5 }

  // Foreign key to Auth DB
  organizationId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
}

model JobAnalyticsSnapshot {
  id             String   @id @default(cuid())
  jobSearchId    String
  jobSearch      JobSearch @relation(fields: [jobSearchId], references: [id], onDelete: Cascade)
  snapshotDate   DateTime @default(now()) // Or just date part if daily snapshots

  // Metrics
  totalMatches      Int
  newMatchesToday   Int
  shortlistedCount  Int
  // ... more specific metrics like average_match_score, time_to_first_shortlist etc.
  analyticsData  Json? // For more flexible/evolving analytics

  // Foreign key to Auth DB
  organizationId String

  @@index([jobSearchId, snapshotDate], name: "job_date_idx")
  @@index([organizationId])
}
