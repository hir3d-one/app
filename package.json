{
  "name": "hir3d",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=@hir3d/app dev --filter=@hir3d/db-auth dev --filter=@hir3d/db-app dev --filter=@hir3d/tasks stripe --filter=@hir3d/app",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:migrate": "turbo run db:migrate --filter=@hir3d/db-auth --filter=@hir3d/db-app"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.5.3",
    "typescript": "5.8.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}