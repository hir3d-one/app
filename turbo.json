{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "db:generate": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build", "^db:generate"],
      "env": [
        "BETTER_AUTH_EMAIL",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "DATABASE_URL_APP",
        "DATABASE_URL_AUTH",
        "GOOGLE_API_KEY",
        "POSTGRES_URL",
        "RESEND_API_KEY",
        "STRIPE_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "TRIGGER_API_URL",
        "TRIGGER_SECRET_KEY"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "stripe": {
      "cache": false,
      "persistent": true
    },
    "@hir3d/db-auth#dev": {
      "cache": false,
      "persistent": true
    },
    "@hir3d/db-app#dev": {
      "cache": false,
      "persistent": true
    },
    "@hir3d/tasks#dev": {
      "cache": false,
      "persistent": true
    },
    "@hir3d/db-auth#db:migrate": {
      "cache": false,
      "interactive": true
    },
    "@hir3d/db-app#db:migrate": {
      "cache": false,
      "interactive": true
    },
    "dev": {
      "dependsOn": ["^db:generate"],
      "cache": false,
      "persistent": true
    }
  }
}
